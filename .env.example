# Supabase - chaves públicas do frontend
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY

# Mercado Pago
# Public key pode ficar no frontend quando for usar SDK no navegador.
VITE_MERCADOPAGO_PUBLIC_KEY=SUA_PUBLIC_KEY

# Access token é segredo. Configure na Vercel, não envie para o navegador.
# Na Vercel: Project Settings > Environment Variables
MERCADOPAGO_ACCESS_TOKEN=SEU_ACCESS_TOKEN_PRIVADO
